policy_package "anomaly_detection" {
  owner "risk-platform"
  domain "security-business-anomalies"
  version "1"
  environments [
    "example"
  ]
  capabilities [
    "routes"
    "lifecycle"
    "decision_table"
    "chain"
    "watch"
    "step"
    "actions"
    "incidents"
  ]
  compatibility "Condition lifecycle and chain runtime"
}
