decision_table "account_takeover_detection" {
  contract "anomaly_actions"
  default allow
  hit_policy first

  row "profile-change-from-new-device" {
    priority 100
    when {
      all {
        route.id == "account_update_profile"
        any {
          session.account.email_changed == true
          session.account.phone_changed == true
          session.account.password_changed == true
          session.account.recovery_changed == true
          session.account.mfa_disabled == true
        }
        any {
          context.device.trusted == false
          context.device.changed == true
          context.network.ip_reputation >= 70
        }
      }
    }
    then {
      outcome {
        decision require_review
        reason "account profile mutation has takeover signals"
        attributes {
          action "account_anomaly"
          threat "account_takeover"
        }
        metadata {
          severity "critical"
          category "account"
        }
      }
    }
    reason "account profile mutation has takeover signals"
    reason_code "ACCOUNT_TAKEOVER_MUTATION"
  }

  row "profile-country-drift" {
    priority 80
    when {
      all {
        route.id == "account_update_profile"
        session.account.profile_country != ""
        context.geo.country != ""
        session.account.profile_country != context.geo.country
      }
    }
    then {
      outcome {
        decision require_review
        reason "account profile country drift detected"
        attributes {
          action "account_anomaly"
          threat "profile_country_drift"
        }
        metadata {
          severity "high"
          category "account"
        }
      }
    }
    reason "account profile country drift detected"
    reason_code "ACCOUNT_COUNTRY_DRIFT"
  }
}
