          severity "high"
          category "account"
        }
      }
    }
    reason "active account step-up requirement"
    reason_code "ACTIVE_ACCOUNT_STEP_UP"
  }

  row "active-geo-suspend" {
    priority 560
    when {
      chain_state.geo_region_policy.step == "suspend_geo_access"
    }
    then {
      outcome {
        decision deny
        reason "active regional suspension"
        attributes {
          result "geo.suspend"
        }
        metadata {
          severity "critical"
          category "geo"
        }
      }
    }
