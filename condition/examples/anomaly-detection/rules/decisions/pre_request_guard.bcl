decision_table "pre_request_guard" {
  contract "anomaly_actions"
  default allow
  hit_policy first

  row "active-session-suspend" {
    priority 600
    when {
      chain_state.identity_session.step == "suspend_identity"
    }
    then {
      outcome {
        decision deny
        reason "active identity suspension"
        attributes {
          result "session.suspend"
        }
        metadata {
          severity "critical"
          category "identity"
        }
      }
    }
    reason "active identity suspension"
    reason_code "ACTIVE_IDENTITY_SUSPEND"
  }

  row "active-session-terminate" {
    priority 590
    when {
      chain_state.identity_session.step == "terminate_session"
    }
    then {
      outcome {
        decision deny
        reason "active session termination"
        attributes {
          result "session.terminate"
        }
        metadata {
          severity "critical"
          category "identity"
        }
      }
    }
    reason "active session termination"
    reason_code "ACTIVE_SESSION_TERMINATE"
  }

  row "active-step-up" {
    priority 580
    when {
      chain_state.identity_session.step == "step_up"
    }
    then {
      outcome {
        decision require_review
        reason "active step-up requirement"
        attributes {
          result "session.step_up"
        }
        metadata {
          severity "high"
          category "identity"
        }
      }
    }
    reason "active step-up requirement"
    reason_code "ACTIVE_STEP_UP"
  }

  row "active-account-suspend" {
    priority 575
    when {
      chain_state.account_takeover.step == "suspend_account_access"
    }
    then {
      outcome {
        decision deny
        reason "active account takeover suspension"
        attributes {
          result "account.suspend"
        }
        metadata {
          severity "critical"
          category "account"
        }
      }
    }
    reason "active account takeover suspension"
    reason_code "ACTIVE_ACCOUNT_SUSPEND"
  }

  row "active-account-terminate" {
    priority 574
    when {
      chain_state.account_takeover.step == "terminate_account_session"
    }
    then {
      outcome {
        decision deny
        reason "active account session termination"
        attributes {
          result "account.terminate"
        }
        metadata {
          severity "critical"
          category "account"
        }
      }
    }
    reason "active account session termination"
    reason_code "ACTIVE_ACCOUNT_TERMINATE"
  }

  row "active-account-step-up" {
    priority 573
    when {
      chain_state.account_takeover.step == "step_up_account"
    }
    then {
