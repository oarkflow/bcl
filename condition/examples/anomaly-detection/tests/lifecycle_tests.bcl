lifecycle_test "account mfa disable from new device triggers step up" {
  lifecycle "http_request"
  phase "post"
  method "POST"
  path "/accounts/update-profile"
  input {
    request.actor_key "acct-1"
  }
  request {
    account {
      mfa_disabled true
    }
    device {
      trusted false
      changed true
    }
    network {
      ip_reputation 75
    }
    format "json"
  }
  response {
    status 200
    body {
      account "updated"
    }
    format "json"
  }
  expect {
    final_action "step_up"
    route "account_update_profile"
  }
}

lifecycle_test "registration request is observed" {
