      role "analyst"
    }
    geo {
      country "DE"
      region "eu"
    }
    business {
      business_hours true
    }
    format "json"
  }
  response {
    status 200
    body {
      ok true
    }
    format "json"
  }
  expect {
    final_action "block"
    route "risk_console"
  }
}

lifecycle_test "blocked country is denied" {
