lifecycle_test "api behavior anomaly is recorded" {
  lifecycle "http_request"
  phase "post"
  method "POST"
  path "/api/resource"
  input {
    request.actor_key "api-client"
    request.application_key "anomaly-detection-demo"
  }
  request {
    api {
      unusual_method_mix true
      endpoint_burst 25
      error_ratio 0.1
    }
    format "json"
  }
  response {
    status 200
    body {
      ok true
    }
    format "json"
  }
  expect {
    final_action "api_behavior_anomaly"
    route "api_resource_mutation"
  }
}

lifecycle_test "api server errors escalate" {
  lifecycle "http_request"
  phase "post"
  method "GET"
  path "/api/resource"
  input {
    request.actor_key "api"
    request.application_key "anomaly-detection-demo"
  }
  request {
    format "json"
  }
  response {
    status 500
    body {
      error "forced"
    }
    format "json"
  }
  expect {
    final_action "api_5xx"
    route "api_resource"
  }
}
