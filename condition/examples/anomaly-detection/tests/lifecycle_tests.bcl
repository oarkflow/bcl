test "expected 401 is healthy" {
  decision "response_observability"
  input {
    response.status 401
    response.healthy true
  }
  expect {
    effect "allow"
    reason_code "HEALTHY_RESPONSE"
  }
}

test "unexpected 404 is unhealthy" {
  decision "response_observability"
  input {
    response.status 404
    response.healthy false
  }
  expect {
    effect "require_review"
    reason_code "UNEXPECTED_4XX"
  }
}

lifecycle_test "trusted session is healthy" {
  lifecycle "http_request"
  phase "post"
  method "POST"
  path "/session/continue"
  input {
    request.actor_key "alice"
  }
  request {
    headers {
      content_type "application/json"
    }
    body {
      actor "alice"
    }
    session {
      impossible_travel false
      token_reuse false
      mfa_bypass_attempt false
    }
    device {
      trusted true
    }
    network {
      asn_changed false
      ip_reputation 10
    }
    format "json"
  }
  response {
    status 200
    body {
      ok true
    }
    format "json"
  }
  expect {
    final_action "healthy"
    route "session_continue"
  }
}

lifecycle_test "impossible travel triggers step up" {
  lifecycle "http_request"
  phase "post"
  method "POST"
  path "/session/continue"
  input {
    request.actor_key "alice"
  }
  request {
    session {
      impossible_travel true
      token_reuse false
      mfa_bypass_attempt false
    }
    network {
      asn_changed false
      ip_reputation 15
    }
    device {
      trusted true
    }
    format "json"
  }
  response {
    status 200
    body {
      ok true
    }
    format "json"
  }
  expect {
    final_action "step_up"
    route "session_continue"
  }
}

lifecycle_test "device change triggers step up" {
