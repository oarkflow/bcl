policy_overlay "example_defaults" {
  layer "environment"
  environment "example"
  metadata {
    owner "platform-security"
    profile "example"
  }
}

policy_overlay "admin_escalation" {
  layer "route"
  route "admin_reports"
  metadata {
    owner "admin-platform"
    escalation_path "security-oncall"
  }
}
