lifecycle "http_request" {
  entity "request.actor_key"
  routes "http"

  phase "post" {
    decision "response_observability"
    decision "login_observability"
    decision "admin_access"
    decision "document_access"
    decision "failure_route_observability"
    chain "account_risk_chain"
    chain "response_error_chain"
  }

  phase "pre" {
    decision "pre_request_guard"
  }

  phase "error" {
    decision "response_observability"
    chain "response_error_chain"
  }
}
