test "api guard allows normal tenant api" {
  decision "global_endpoint_guard"
  input {
    endpoint.policy_type "api_endpoint"
    endpoint.pattern "/api/v1/tenants/{tenant}/users/{user_id}"
    request.requests_per_minute 3
    request.burst_count 4
    request.banned false
  }
  expect { effect "allow" reason_code "API_GUARD_ALLOW" }
}

test "api guard rate limits tenant api" {
  decision "tenant_user_endpoint_guard"
  input {
    endpoint.policy_type "api_endpoint"
    endpoint.pattern "/api/v1/tenants/{tenant}/users/{user_id}"
    request.requests_per_minute 7
    request.burst_count 7
    request.banned false
  }
  expect { effect "require_review" reason_code "API_GUARD_RATE_LIMIT" }
}

test "api guard bans busy admin endpoint" {
  decision "admin_endpoint_guard"
  input {
    endpoint.policy_type "rbac"
    endpoint.pattern "/admin/*"
    request.requests_per_minute 8
    request.burst_count 8
    request.banned true
  }
  expect { effect "deny" reason_code "API_GUARD_BAN" }
}

test "api guard soft warns document burst" {
  decision "document_endpoint_guard"
  input {
    endpoint.policy_type "acl"
    endpoint.pattern "/documents/{document_id}"
    request.requests_per_minute 5
    request.burst_count 5
    request.banned false
  }
  expect { effect "allow" reason_code "API_GUARD_SOFT_WARNING" }
}

test "rbac admin endpoint" {
  decision "admin_auth_guard"
  input {
    global.maintenance_mode false
    request.safe_method true
    request.write_method false
    request.business_hours true
    principal.authenticated true
    principal.active true
    principal.role "admin"
    principal.admin_role true
    principal.same_tenant false
    principal.department_matches false
    principal.device_trusted true
    principal.acl_granted false
    endpoint.match_kind "wildcard"
    endpoint.policy_type "rbac"
  }
  expect { effect "allow" reason_code "RBAC_ADMIN" }
}

test "rbac analyst denied" {
  decision "admin_auth_guard"
  input {
    global.maintenance_mode false
    request.safe_method true
    request.write_method false
    request.business_hours true
    principal.authenticated true
    principal.active true
    principal.role "analyst"
    principal.admin_role false
    principal.same_tenant false
    principal.department_matches false
    principal.device_trusted true
    principal.acl_granted false
    endpoint.match_kind "wildcard"
    endpoint.policy_type "rbac"
  }
  expect { effect "deny" reason_code "POLICY_DENY" }
}

test "abac project endpoint" {
  decision "project_auth_guard"
  input {
    global.maintenance_mode false
    request.safe_method true
    request.write_method false
    request.business_hours true
    principal.authenticated true
    principal.active true
    principal.role "analyst"
    principal.admin_role false
    principal.same_tenant true
    principal.department_matches true
    principal.device_trusted true
    principal.acl_granted false
    endpoint.match_kind "dynamic"
    endpoint.policy_type "abac"
    endpoint.tenant_param "acme"
  }
  expect { effect "allow" reason_code "ABAC_PROJECT" }
}

test "acl document endpoint" {
  decision "document_auth_guard"
  input {
    global.maintenance_mode false
    request.safe_method true
    request.write_method false
    request.business_hours true
    principal.authenticated true
    principal.active true
    principal.role "viewer"
    principal.admin_role false
    principal.same_tenant false
    principal.department_matches false
    principal.device_trusted true
    principal.acl_granted true
    endpoint.match_kind "dynamic"
    endpoint.policy_type "acl"
    endpoint.document_param "alpha"
  }
  expect { effect "allow" reason_code "ACL_DOCUMENT" }
}

test "public endpoint allowed globally" {
  decision "global_auth_guard"
  input {
    endpoint.policy_type "public"
    principal.authenticated false
  }
  expect { effect "allow" reason_code "PUBLIC_ALLOW" }
}

test "tenant api write denied for analyst" {
  decision "tenant_user_auth_guard"
  input {
    request.safe_method false
    request.write_method true
    principal.active true
    principal.admin_role false
    principal.same_tenant true
    principal.device_trusted true
    endpoint.match_kind "dynamic"
    endpoint.policy_type "api_endpoint"
    endpoint.api_scope "tenant-user"
    endpoint.tenant_param "acme"
    endpoint.user_param "u-analyst"
  }
  expect { effect "deny" reason_code "POLICY_DENY" }
}

test "endpoint 5xx observed" {
  decision "response_observability"
  input {
    route.id "endpoint_failure"
    response.status 500
  }
  expect { effect "require_review" reason_code "ENDPOINT_5XX" }
}

test "application 5xx observed" {
  decision "response_observability"
  input {
    route.id "other"
    response.status 502
  }
  expect { effect "require_review" reason_code "APP_5XX" }
}

test "unexpected 4xx observed" {
  decision "response_observability"
  input {
    route.id "other"
    response.status 404
  }
  expect { effect "require_review" reason_code "UNEXPECTED_4XX" }
}

test "expected 403 is healthy" {
  decision "response_observability"
  input {
    route.id "other"
    response.status 403
  }
  expect { effect "allow" reason_code "RESPONSE_HEALTHY" }
}

lifecycle_test "pre public status allowed" {
  lifecycle "http_request"
  phase "pre"
  method "GET"
  path "/public/status"
  input {
    request.actor_key "anonymous"
    request.safe_method true
    request.write_method false
    request.business_hours true
    request.requests_per_minute 1
    request.burst_count 1
    request.banned false
    endpoint.policy_type "public"
    endpoint.pattern "/public/status"
    principal.authenticated false
  }
  request {
    headers { accept "application/json" x_request_id "req-public-status" }
    body { path "/public/status" }
    format "json"
  }
  expect {
    final_action "public_allow"
    route "public_status"
  }
}

lifecycle_test "post endpoint failure logs first event" {
  lifecycle "http_request"
  phase "post"
  method "GET"
  path "/fail/endpoint"
  input { request.actor_key "/fail/endpoint" }
  request {
    headers { accept "application/json" x_request_id "req-endpoint-failure" }
    body { path "/fail/endpoint" }
    format "json"
  }
  response {
    status 500
    headers { content_type "text/plain" }
    body { error "endpoint failure" }
    format "text"
  }
  expect {
    final_action "log"
    route "endpoint_failure"
  }
}
