{
  "BCL version": {
    "prefix": "bcl",
    "body": [
      "bcl {",
      "  version \"${1:1.0}\"",
      "  strict ${2:true}",
      "}"
    ],
    "description": "BCL version declaration"
  },
  "Schema": {
    "prefix": "schema",
    "body": [
      "schema ${1:name} {",
      "  required ${2:field} ${3:string}",
      "}"
    ],
    "description": "Schema declaration"
  },
  "Comprehensive schema": {
    "prefix": "schema_object",
    "body": [
      "schema ${1:name} {",
      "  required ${2:payload} object {",
      "    closed true",
      "    title \"${3:Payload}\"",
      "    description \"${4:Validated input contract}\"",
      "",
      "    required ${5:id} string default uuid() generated format uuid description \"Stable identifier\"",
      "    optional ${6:created_at} string default current_timestamp() generated format date-time read_only",
      "    optional ${7:tags} list items string min_items 0 max_items 20 unique_items",
      "  }",
      "}"
    ],
    "description": "Comprehensive schema object with generated defaults"
  },
  "Sectioned schema": {
    "prefix": "schema_sectioned",
    "body": [
      "schema ${1:name} {",
      "  options {",
      "    validate_required_fields true",
      "    validate_field_types true",
      "  }",
      "",
      "  fields {",
      "    ${2:id} ${3:string} required default ${4:uuid()}",
      "  }",
      "",
      "  ${5:workflow} {",
      "    owner \"${6:team}\"",
      "  }",
      "}"
    ],
    "description": "Extensible schema with options, field-first fields, and custom DSL sections"
  },
  "Schema field": {
    "prefix": "sfield",
    "body": [
      "${1|required} ${2:name} ${3|string} ${4:description \"${5:description}\"}"
    ],
    "description": "Schema field"
  },
  "Schema field block": {
    "prefix": "sfield_block",
    "body": [
      "${1|required} ${2:name} ${3|string} {",
      "  description \"${4:description}\"",
      "  ${5:format email}",
      "}"
    ],
    "description": "Schema field using block clauses"
  },
  "Schema generated id": {
    "prefix": "sgenid",
    "body": [
      "optional ${1:id} string default ${2:uid(\"id\")} generated format uuid"
    ],
    "description": "Generated schema identifier"
  },
  "Schema generated timestamp": {
    "prefix": "sgents",
    "body": [
      "optional ${1:created_at} string default ${2|current_timestamp(),now()|} generated format date-time"
    ],
    "description": "Generated schema timestamp"
  },
  "Policy": {
    "prefix": "policy",
    "body": [
      "policy \"${1:name}\" {",
      "  effect ${2:allow}",
      "}"
    ],
    "description": "Policy block"
  },
  "Set": {
    "prefix": "set",
    "body": [
      "set \"${1:name}\" {",
      "  ${2:item}",
      "}"
    ],
    "description": "Reusable set"
  },
  "Pipeline": {
    "prefix": "pipeline",
    "body": [
      "pipeline \"${1:name}\" {",
      "  entrypoint \"${2:start}\"",
      "",
      "  step \"${2:start}\" {",
      "    type ${3:action}",
      "  }",
      "}"
    ],
    "description": "Workflow pipeline"
  },
  "Decision schema": {
    "prefix": "decision_schema",
    "body": [
      "decision_schema \"${1:name}\" {",
      "  effects [${2:allow}, ${3:deny}, ${4:require_review}]",
      "  default ${4:require_review}",
      "  strategy ${5:first_match}",
      "}"
    ],
    "description": "Decision schema contract"
  },
  "Decision table": {
    "prefix": "decision_table",
    "body": [
      "decision_table \"${1:name}\" {",
      "  default ${2:require_review}",
      "  hit_policy ${3:first}",
      "",
      "  row \"${4:rule-id}\" {",
      "    phase ${5:decide}",
      "    priority ${6:10}",
      "    when { ${7:condition} }",
      "    then {",
      "      outcome {",
      "        decision ${8:allow}",
      "        reason \"${9:reason}\"",
      "      }",
      "    }",
      "  }",
      "}"
    ],
    "description": "Decision table with one row"
  },
  "Dataset": {
    "prefix": "dataset",
    "body": [
      "dataset \"${1:name}\" {",
      "  record \"${2:record}\" {",
      "    ${3:field} ${4:value}",
      "  }",
      "}"
    ],
    "description": "Decision dataset"
  },
  "Test matrix": {
    "prefix": "test_matrix",
    "body": [
      "test_matrix \"${1:name}\" {",
      "  decision \"${2:decision_name}\"",
      "",
      "  case \"${3:case}\" {",
      "    input {",
      "      ${4:field} ${5:value}",
      "    }",
      "    expect {",
      "      effect \"${6:allow}\"",
      "    }",
      "  }",
      "}"
    ],
    "description": "Decision test matrix"
  },
  "Reason code catalog": {
    "prefix": "reason_code_catalog",
    "body": [
      "reason_code_catalog \"${1:name}\" {",
      "  code \"${2:CODE}\" { description \"${3:description}\" }",
      "}"
    ],
    "description": "Reason code catalog"
  },
  "Release gate": {
    "prefix": "gate",
    "body": [
      "gate \"${1:name}\" {",
      "  bundle \"${2:bundle}\"",
      "  decision \"${3:decision}\"",
      "  dataset \"${4:dataset}\"",
      "  min_pass_rate ${5:1.0}",
      "  max_diagnostics ${6:0}",
      "}"
    ],
    "description": "Decision release gate"
  },
  "Rule template": {
    "prefix": "rule_template",
    "body": [
      "rule_template \"${1:name}\" {",
      "  row \"${2:row-id}\" {",
      "    phase ${3:decide}",
      "    priority ${4:10}",
      "    when { ${5:condition} }",
      "    then { outcome { decision ${6:require_review} reason \"${7:reason}\" } }",
      "  }",
      "}"
    ],
    "description": "Reusable decision row template"
  },
  "Chain": {
    "prefix": "chain",
    "body": [
      "chain \"${1:name}\" {",
      "  entity \"${2:request.actor_key}\"",
      "  decision \"${3:decision_name}\"",
      "",
      "  watch \"${4:event_watch}\" {",
      "    event \"${5:event_type}\"",
      "    window \"${6:10m}\"",
      "    distinct \"${7:attributes.user_id}\"",
      "    field \"${8:attributes.duration_ms}\"",
      "    metrics [\"count\", \"rate\", \"min\", \"max\", \"avg\", \"p95\", \"p99\"]",
      "    decay \"${9:1h}\"",
      "    cooldown \"${10:10m}\"",
      "    reset \"${11:remediated}\"",
      "    step \"${12:notify}\" { threshold ${13:3} action \"${14:notify}\" severity \"${15:high}\" ttl \"${16:15m}\" }",
      "  }",
      "}"
    ],
    "description": "Stateful policy chain with watch and threshold step"
  },
  "Route catalog": {
    "prefix": "routes",
    "body": [
      "routes \"${1:http}\" {",
      "  route \"${2:route_id}\" {",
      "    method \"${3|GET,POST,PUT,PATCH,DELETE|}\"",
      "    pattern \"${4:/items/{id}}\"",
      "    metadata { category \"${5:api}\" }",
      "  }",
      "}"
    ],
    "description": "HTTP route catalog for lifecycle evaluation"
  },
  "Lifecycle": {
    "prefix": "lifecycle",
    "body": [
      "lifecycle \"${1:http_request}\" {",
      "  entity \"${2:request.actor_key}\"",
      "  routes \"${3:http}\"",
      "",
      "  phase \"${4:pre}\" {",
      "    decision \"${5:guard_decision}\"",
      "  }",
      "",
      "  phase \"${6:post}\" {",
      "    decision \"${7:response_observability}\"",
      "    chain \"${8:response_error_chain}\"",
      "  }",
      "}"
    ],
    "description": "Generic request lifecycle with pre/post phases"
  },
  "Policy package": {
    "prefix": "policy_package",
    "body": [
      "policy_package \"${1:security}\" {",
      "  owner \"${2:platform-security}\"",
      "  domain \"${3:auth}\"",
      "  version \"${4:1.0.0}\"",
      "  capabilities [\"${5:state}\", \"${6:routes}\", \"${7:actions}\"]",
      "  routes [\"${8:http}\"]",
      "  actions [\"allow\", \"deny\", \"notify\"]",
      "  state true",
      "  external false",
      "}"
    ],
    "description": "Condition policy package manifest"
  },
  "Policy overlay": {
    "prefix": "policy_overlay",
    "body": [
      "policy_overlay \"${1:tenant_strict}\" {",
      "  layer \"${2:tenant}\"",
      "  tenant \"${3:tenant-a}\"",
      "  environment \"${4:production}\"",
      "  metadata {",
      "    ${5:risk_tier} \"${6:strict}\"",
      "  }",
      "}"
    ],
    "description": "Deterministic global/environment/tenant/endpoint/route metadata overlay"
  },
  "Action catalog": {
    "prefix": "action_catalog",
    "body": [
      "action_catalog \"${1:default}\" {",
      "  action \"${2:allow}\" { sink \"event\" severity \"low\" }",
      "  action \"${3:deny}\" { sink \"event\" severity \"high\" approval \"required\" retries 1 }",
      "  action \"${4:notify}\" { sinks [\"event\", \"webhook\"] severity \"high\" approval \"required\" retries 3 }",
      "}"
    ],
    "description": "Allowed action names, sinks, severities, retry and approval metadata"
  },
  "Output contract": {
    "prefix": "output_contract",
    "body": [
      "output_contract \"${1:guard_output}\" {",
      "  actions [\"${2:allow}\", \"${3:deny}\", \"${4:notify}\"]",
      "  severities [\"${5:low}\", \"${6:medium}\", \"${7:high}\", \"${8:critical}\"]",
      "}"
    ],
    "description": "Allowed actions and severities for decisions, chains, and lifecycles"
  },
  "Standard facts": {
    "prefix": "standard_facts",
    "body": [
      "standard_facts \"${1:http}\" {",
      "  fact \"request\" { schema \"${2:http_request}\" }",
      "  fact \"response\" { schema \"${3:http_response}\" }",
      "  fact \"principal\" { schema \"${4:principal}\" }",
      "  fact \"route\" { schema \"${5:route_fact}\" }",
      "  fact \"tenant\" { schema \"${6:tenant_fact}\" }",
      "  fact \"resource\" { schema \"${7:resource_fact}\" }",
      "  fact \"risk\" { schema \"${8:risk_fact}\" }",
      "  fact \"state\" { schema \"${9:state_fact}\" }",
      "}"
    ],
    "description": "Typed standard fact contracts for lifecycle and decision inputs"
  },
  "Response classifier": {
    "prefix": "response_classifier",
    "body": [
      "response_classifier \"${1:http}\" {",
      "  healthy_below ${2:400}",
      "  unhealthy_at_or_above ${3:500}",
      "  expected_client_statuses [400, 401, 403]",
      "}"
    ],
    "description": "HTTP response classification defaults for lifecycle post-response policies"
  },
  "Lifecycle test": {
    "prefix": "lifecycle_test",
    "body": [
      "lifecycle_test \"${1:post server error}\" {",
      "  lifecycle \"${2:http_request}\"",
      "  phase \"${3:post}\"",
      "  method \"${4:GET}\"",
      "  path \"${5:/items/123}\"",
      "  input { request.actor_key \"${6:user-1}\" }",
      "  request {",
      "    headers { content_type \"application/json\" x_request_id \"${7:req-123}\" }",
      "    body { id \"${8:item-123}\" }",
      "    format \"json\"",
      "  }",
      "  response {",
      "    status ${9:500}",
      "    headers { content_type \"application/json\" }",
      "    body { error \"${10:upstream timeout}\" }",
      "    format \"json\"",
      "  }",
      "  expect {",
      "    final_action \"${11:notify}\"",
      "    route \"${12:items}\"",
      "  }",
      "}"
    ],
    "description": "Executable lifecycle scenario test"
  }
}
