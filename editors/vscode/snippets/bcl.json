{
  "BCL version": {
    "prefix": "bcl",
    "body": [
      "bcl {",
      "  version \"${1:1.0}\"",
      "  strict ${2:true}",
      "}"
    ],
    "description": "BCL version declaration"
  },
  "Schema": {
    "prefix": "schema",
    "body": [
      "schema ${1:name} {",
      "  required ${2:field} ${3:string}",
      "}"
    ],
    "description": "Schema declaration"
  },
  "Policy": {
    "prefix": "policy",
    "body": [
      "policy \"${1:name}\" {",
      "  effect ${2:allow}",
      "}"
    ],
    "description": "Policy block"
  },
  "Set": {
    "prefix": "set",
    "body": [
      "set \"${1:name}\" {",
      "  ${2:item}",
      "}"
    ],
    "description": "Reusable set"
  },
  "Pipeline": {
    "prefix": "pipeline",
    "body": [
      "pipeline \"${1:name}\" {",
      "  entrypoint \"${2:start}\"",
      "",
      "  step \"${2:start}\" {",
      "    type ${3:action}",
      "  }",
      "}"
    ],
    "description": "Workflow pipeline"
  },
  "Decision schema": {
    "prefix": "decision_schema",
    "body": [
      "decision_schema \"${1:name}\" {",
      "  effects [${2:allow}, ${3:deny}, ${4:require_review}]",
      "  default ${4:require_review}",
      "  strategy ${5:first_match}",
      "}"
    ],
    "description": "Decision schema contract"
  },
  "Decision table": {
    "prefix": "decision_table",
    "body": [
      "decision_table \"${1:name}\" {",
      "  default ${2:require_review}",
      "  hit_policy ${3:first}",
      "",
      "  row \"${4:rule-id}\" {",
      "    phase ${5:decide}",
      "    priority ${6:10}",
      "    when { ${7:condition} }",
      "    then {",
      "      outcome {",
      "        decision ${8:allow}",
      "        reason \"${9:reason}\"",
      "      }",
      "    }",
      "  }",
      "}"
    ],
    "description": "Decision table with one row"
  },
  "Dataset": {
    "prefix": "dataset",
    "body": [
      "dataset \"${1:name}\" {",
      "  record \"${2:record}\" {",
      "    ${3:field} ${4:value}",
      "  }",
      "}"
    ],
    "description": "Decision dataset"
  },
  "Test matrix": {
    "prefix": "test_matrix",
    "body": [
      "test_matrix \"${1:name}\" {",
      "  decision \"${2:decision_name}\"",
      "",
      "  case \"${3:case}\" {",
      "    input {",
      "      ${4:field} ${5:value}",
      "    }",
      "    expect {",
      "      effect \"${6:allow}\"",
      "    }",
      "  }",
      "}"
    ],
    "description": "Decision test matrix"
  },
  "Reason code catalog": {
    "prefix": "reason_code_catalog",
    "body": [
      "reason_code_catalog \"${1:name}\" {",
      "  code \"${2:CODE}\" { description \"${3:description}\" }",
      "}"
    ],
    "description": "Reason code catalog"
  },
  "Release gate": {
    "prefix": "gate",
    "body": [
      "gate \"${1:name}\" {",
      "  bundle \"${2:bundle}\"",
      "  decision \"${3:decision}\"",
      "  dataset \"${4:dataset}\"",
      "  min_pass_rate ${5:1.0}",
      "  max_diagnostics ${6:0}",
      "}"
    ],
    "description": "Decision release gate"
  },
  "Rule template": {
    "prefix": "rule_template",
    "body": [
      "rule_template \"${1:name}\" {",
      "  row \"${2:row-id}\" {",
      "    phase ${3:decide}",
      "    priority ${4:10}",
      "    when { ${5:condition} }",
      "    then { outcome { decision ${6:require_review} reason \"${7:reason}\" } }",
      "  }",
      "}"
    ],
    "description": "Reusable decision row template"
  }
}
