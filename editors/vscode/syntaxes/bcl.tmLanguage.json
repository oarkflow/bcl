{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "BCL",
  "scopeName": "source.bcl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#blocks"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.bcl",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.bcl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.bcl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.bcl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.bcl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.raw.bcl",
          "begin": "`",
          "end": "`"
        },
        {
          "name": "string.unquoted.heredoc.bcl",
          "begin": "<<\\s*([A-Za-z_][A-Za-z0-9_-]*)",
          "end": "^\\s*\\1\\s*$"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.bcl",
          "match": "\\b\\d+(?:\\.\\d+)?(?:[A-Za-z]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.bcl",
          "match": "\\b(import|as|const|type|schema|required|optional|enum|default|description|doc|deprecated|sensitive|generated|min|max|pattern|format|examples|when|override|true|false|null|match|case|else)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.bcl",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "blocks": {
      "patterns": [
        {
          "name": "entity.name.type.block.bcl",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_-]*)(?=\\s+(?:\"|[A-Za-z0-9_-]+)\\s*\\{)",
          "captures": {
            "1": {
              "name": "entity.name.type.block.bcl"
            }
          }
        },
        {
          "name": "entity.name.tag.id.bcl",
          "match": "\\b[A-Za-z_][A-Za-z0-9_.-]*\\b(?=\\s*\\{)"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.bcl",
          "match": "==|!=|<=|>=|&&|\\|\\||[=<>!+*/%-]|\\b(in|not_in|contains|starts_with|ends_with|matches|has|has_any|has_all|between|exists|empty|equals|greater_than|less_than|greater_or_equal|less_or_equal|and|or|to)\\b"
        }
      ]
    }
  }
}
